# ── Residential Proxy (Optional) ──────────────────────────────────────
# Datacenter IPs (Render, AWS, GCP) are blocked by X. A residential proxy
# is required when hosting in the cloud. Tested providers: DataImpulse, Smartproxy.
# Format: http://username:password@host:port
# Leave blank to disable (only works if your local/server IP is not flagged).
PROXY_URL=

# ── X Session Cookies ─────────────────────────────────────────────────
# auth_token and ct0 are NO LONGER stored here as env vars.
# Pass them dynamically per request in the JSON body of POST /tweet and POST /debug-tweet.
# See README.md → "How to get your X Cookies" for extraction steps.
