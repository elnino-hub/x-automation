# ── X (Twitter) Session Cookies ──────────────────────────────────────
# Get these from your browser after logging in to x.com:
# DevTools → Application → Cookies → https://x.com
# Cookies last ~12 months. Re-export when you see AUTH_EXPIRED errors.
X_AUTH_TOKEN=your_auth_token_cookie_here
X_CT0=your_ct0_cookie_here

# ── Service Authentication ────────────────────────────────────────────
# Any long random string. Clients must send this in the x-api-key header.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me-to-a-long-random-string

# ── Residential Proxy (Required) ──────────────────────────────────────
# Datacenter IPs (Render, AWS, GCP) are blocked by X. A residential proxy
# is required. Tested providers: DataImpulse, Smartproxy.
# Format: http://username:password@host:port
# Leave blank to disable (only works if your IP is not flagged).
PROXY_URL=
